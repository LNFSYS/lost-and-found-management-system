# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fptu_lost_found
DB_USER=YOUR_VALUE_HERE
DB_PASSWORD=YOUR_VALUE_HERE
MYSQL_ROOT_PASSWORD=YOUR_VALUE_HERE

# JWT
JWT_ACCESS_SECRET=YOUR_VALUE_HERE
JWT_REFRESH_SECRET=YOUR_VALUE_HERE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
# Create credentials at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=YOUR_VALUE_HERE
CLOUDINARY_API_KEY=YOUR_VALUE_HERE
CLOUDINARY_API_SECRET=YOUR_VALUE_HERE

# Google OAuth
# Create OAuth 2.0 credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=YOUR_VALUE_HERE
GOOGLE_CLIENT_SECRET=YOUR_VALUE_HERE
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google Cloud Vision
# Option A: service account JSON key path.
GOOGLE_APPLICATION_CREDENTIALS=YOUR_VALUE_HERE
# Option B: API key for demo usage.
GOOGLE_VISION_API_KEY=YOUR_VALUE_HERE

# Email SMTP
# Use credentials from Gmail App Password, SendGrid, Mailgun, or another SMTP provider.
SMTP_HOST=YOUR_VALUE_HERE
SMTP_PORT=587
SMTP_USER=YOUR_VALUE_HERE
SMTP_PASS=YOUR_VALUE_HERE
SMTP_FROM=YOUR_VALUE_HERE

# Node API
NODE_ENV=development
API_PORT=3001
WEB_PORT=8080
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3001/api
BCRYPT_SALT_ROUNDS=12
LOG_FORMAT=pretty
LOG_LEVEL=info
TRUST_PROXY=false
HEALTH_CHECK_TIMEOUT_MS=2000
SHUTDOWN_TIMEOUT_MS=10000
METRICS_TOKEN=YOUR_VALUE_HERE

# Optional for local development; recommended for multi-instance API deployment.
# REDIS_URL=redis://localhost:6379
# Set true only where Redis is an enforced runtime dependency (for example, scaled production).
REDIS_REQUIRED=false
REDIS_CONNECT_TIMEOUT_MS=3000

# Java Admin Service
JAVA_SERVICE_PORT=8080
JAVA_JWT_SECRET=YOUR_VALUE_HERE
# Keep false while Node.js owns core writes. Enable only when a flow is explicitly routed to Java.
JAVA_WRITES_ENABLED=false

# Socket.IO
SOCKET_CORS_ORIGIN=http://localhost:5173
