NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:5173
LOG_FORMAT=pretty
LOG_LEVEL=info
# Set to 1 when deployed behind one trusted reverse proxy.
TRUST_PROXY=false
HEALTH_CHECK_TIMEOUT_MS=2000
SHUTDOWN_TIMEOUT_MS=10000
# Protect /api/metrics in production. Without this token the endpoint is hidden in production.
METRICS_TOKEN=YOUR_VALUE_HERE

# Optional. When configured, rate limiting and Socket.IO use distributed Redis state.
# REDIS_URL=redis://localhost:6379
# Keep false for local development so the API can use in-memory rate limits and single-process sockets.
REDIS_REQUIRED=false
REDIS_CONNECT_TIMEOUT_MS=3000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=fptu_lost_found
DB_USER=YOUR_VALUE_HERE
DB_PASSWORD=YOUR_VALUE_HERE
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# Use either a CA file path or an escaped inline certificate when your cloud MySQL requires SSL.
# DB_SSL_CA_PATH=./certs/aiven-ca.pem
# DB_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

JWT_ACCESS_SECRET=YOUR_VALUE_HERE
JWT_REFRESH_SECRET=YOUR_VALUE_HERE
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
TRAINING_EXPORT_SECRET=YOUR_VALUE_HERE

# Create credentials at https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=YOUR_VALUE_HERE
CLOUDINARY_API_KEY=YOUR_VALUE_HERE
CLOUDINARY_API_SECRET=YOUR_VALUE_HERE

# Create OAuth 2.0 credentials in Google Cloud Console.
GOOGLE_CLIENT_ID=YOUR_VALUE_HERE
GOOGLE_CLIENT_SECRET=YOUR_VALUE_HERE
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Google Cloud Vision. Use either service account JSON path or API key.
GOOGLE_APPLICATION_CREDENTIALS=YOUR_VALUE_HERE
GOOGLE_VISION_API_KEY=YOUR_VALUE_HERE

# Use credentials from Gmail App Password, SendGrid, Mailgun, or another SMTP provider.
SMTP_HOST=YOUR_VALUE_HERE
SMTP_PORT=587
SMTP_USER=YOUR_VALUE_HERE
SMTP_PASS=YOUR_VALUE_HERE
SMTP_FROM=noreply@yourdomain.com

SOCKET_CORS_ORIGIN=http://localhost:5173
