{
  "name": "fptu-lost-found-system",
  "private": true,
  "version": "0.1.0",
  "description": "AI-assisted Lost & Found MVP for FPT University Da Nang campus.",
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:all": "concurrently -n API,WEB,JAVA -c blue,green,yellow \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:java\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api-node run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:java": "mvn -f apps/java-admin-service/pom.xml spring-boot:run",
    "check:db": "npm --workspace apps/api-node run check:db",
    "export:training-data": "npm --workspace apps/api-node run export:training-data",
    "train:match-model": "npm --workspace apps/api-node run train:match-model",
    "perf:smoke": "npm --workspace apps/api-node run perf:smoke",
    "perf:seed": "npm --workspace apps/api-node run perf:seed",
    "perf:query-plan": "npm --workspace apps/api-node run perf:query-plan",
    "e2e:core": "npm --workspace apps/api-node run e2e:core",
    "e2e:roles": "npm --workspace apps/api-node run e2e:roles",
    "e2e:warehouse": "npm --workspace apps/api-node run e2e:warehouse",
    "e2e:claim-race": "npm --workspace apps/api-node run e2e:claim-race",
    "e2e:media-privacy": "npm --workspace apps/api-node run e2e:media-privacy",
    "e2e:chat-gating": "npm --workspace apps/api-node run e2e:chat-gating",
    "e2e:claim-evidence-policy": "npm --workspace apps/api-node run e2e:claim-evidence-policy",
    "e2e:admin-crud": "npm --workspace apps/api-node run e2e:admin-crud",
    "e2e:runtime-hardening": "npm --workspace apps/api-node run e2e:runtime-hardening",
    "e2e:web": "npm --workspace apps/web run e2e",
    "migrate:api": "npm --workspace apps/api-node run migrate",
    "seed:demo": "npm --workspace apps/api-node run seed:demo",
    "repair:encoding": "npm --workspace apps/api-node run repair:encoding",
    "smoke:migration": "npm --workspace apps/api-node run smoke:migration",
    "test:api": "npm --workspace apps/api-node run test",
    "test:mobile": "npm --workspace apps/mobile run test",
    "build": "npm run build:api && npm run build:web",
    "build:all": "npm run build:api && npm run build:web && npm run build:java",
    "check": "npm run build",
    "check:all": "npm run build:all",
    "build:web": "npm --workspace apps/web run build",
    "build:api": "npm --workspace apps/api-node run build",
    "build:java": "mvn -f apps/java-admin-service/pom.xml package -DskipTests",
    "typecheck:mobile": "npm --workspace apps/mobile run typecheck",
    "lint:web": "npm --workspace apps/web run lint",
    "scan:secrets": "node scripts/secret-scan.mjs",
    "scan:secrets:workspace": "node scripts/secret-scan.mjs --workspace",
    "scan:text": "node scripts/release-quality-check.mjs",
    "package:release": "node scripts/release-package.mjs",
    "quality:release": "npm run scan:secrets && node scripts/release-quality-check.mjs && npm run build:api && npm run build:web && npm run typecheck:mobile && npm run smoke:migration"
  },
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
